---
import type { CVContent } from "../content/types";

interface Props {
  content: CVContent;
}
const { content } = Astro.props;
---

<section id="skills">
  <div class="section-header">
    <span class="section-num">02</span>
    <h2 class="section-title">{content.sectionTitles.skills}</h2>
  </div>

  <div class="skills-grid">
    {content.skills.map((row) => (
      <div class="skill-row">
        <div class="skill-cat">{row.category}</div>
        <div class="skill-tags">
          {row.tags.map((tag) => (
            <span class:list={["skill-tag", row.lead && "is-lead"]}>{tag}</span>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
